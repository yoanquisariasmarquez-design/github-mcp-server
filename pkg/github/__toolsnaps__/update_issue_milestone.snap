      },
      "milestone": {
        "description": "The milestone number to set on the issue",
        "minimum": 1,
        "type": "integer"
      },
      "owner": {
        "description": "Repository owner (username or organization)",
        "type": "string"
      },
      "repo": {
        "description": "Repository name",
        "type": "string"
      }
    },
    "required": [
      "owner",
      "repo",
      "issue_number",
      "milestone"
    ],
    "type": "object"
  },
  "name": "update_issue_milestone"
}