    "properties": {
      "threadID": {
        "description": "The node ID of the review thread to unresolve (e.g., PRRT_kwDOxxx)",
        "type": "string"
      }
    },
    "required": [
      "threadID"
    ],
    "type": "object"
  },
  "name": "unresolve_review_thread"
}